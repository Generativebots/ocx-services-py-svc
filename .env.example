# =============================================================================
# OCX Python Services — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit .env with real credentials.
# These are the same variables configured in GitHub Secrets for CI/CD.
# =============================================================================

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_SA_KEY=                          # JSON key (used in CI only, not locally)

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db.YOUR_PROJECT.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# ── Application ──────────────────────────────────────────────────────────────
DB_BACKEND=postgresql
OCX_ENV=dev

# ── LLM Jury (Multi-Model Cognitive Auditing) ───────────────────────────────
# These enable real multi-model jury votes instead of rule-based simulation.
# If any key is empty, that juror falls back to deterministic rules.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...
OCX_INTENT_LLM=false              # Set "true" to use LLM for intent extraction
